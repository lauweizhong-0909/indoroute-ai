# ---------------------------------------------------
# 机密信息与环境变量 (极其重要，绝对不能漏)
# ---------------------------------------------------
.env
.env.*
!.env.example
!**/.env.example

# ---------------------------------------------------
# Python & 虚拟环境 (解决你 240 多个改动的元凶)
# ---------------------------------------------------
.venv/
.venv_broken_*/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ---------------------------------------------------
# Node.js & 前端框架
# ---------------------------------------------------
node_modules/
apps/web/node_modules/

# pnpm
.pnpm-store/
package-lock.json

# Next.js
.next/
out/
apps/web/.next/
apps/web/out/
build/

# ---------------------------------------------------
# 编辑器与系统生成文件
# ---------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local runtime logs
/*.log
/*.err.log
